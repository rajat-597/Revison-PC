class LinearSearch {
    public static void main(String[] args) {
        int arr [] = {1,2,3,8,4,6,7};
        
        int target = 8;
        boolean flag = false;
        for(int i=0; i<arr.length; i++){
            if(arr[i] == target){
                 System.out.println("Element found at index " + i);
                 flag = true;
            }
        }
        
        if(!flag){
             System.out.println("Element not found ");
        }
       
    }
}
