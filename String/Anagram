import java.util.Arrays;

class Anagram {
    public static void main(String[] args) {
        String str1 = "Silete";
        String str2 = "Listen";
        
        char [] word1 =  str1.toLowerCase().replaceAll("\\s","").toCharArray();
        char [] word2 =  str2.toLowerCase().replaceAll("\\s","").toCharArray();
        
        // sort the array
        Arrays.sort(word1);
        Arrays.sort(word2);
        
        // compare the Array
        if(Arrays.equals(word1, word2)){
            System.out.println("Anagram");
        }else{
            System.out.println("not anagram");
        }
