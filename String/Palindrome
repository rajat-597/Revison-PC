class Palindrome {
    public static void main(String[] args) {
        
        String str = "madam";
        String originalStr = str;
        
        String rev = "";
        for(int i = 0; i<str.length(); i++){
            rev = str.charAt(i) + rev;
        }
        
             System.out.println(rev);
             if(rev.equals(originalStr)){
                 System.out.println("Paliandrome String");
             }else{
                 System.out.println("Not a Paliandrome String");
             }
    }
}
