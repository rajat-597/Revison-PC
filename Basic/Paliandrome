class Paliandrome {
    public static void main(String[] args) {
     
     // reverse a number
     int n = 121;
     int on = n;
     int rev = 0;
     while(n!=0){
         int digit = n%10;
         rev = rev*10+digit;
         n = n/10;
     }
     if(rev == on){
       System.out.println("The Given number is paliandrome");
     }else{
         System.out.println("The Given number is not paliandrome");
     }
    }
}
